# Copy this file to server/.env and fill in the values before starting the stack.

# PostgreSQL
PGHOST=db
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=wheresmybus
PGPORT=5432

# GTFS Real-time feeds (TransLink SEQ)
GTFS_RT_TRIP_UPDATES_URL=https://gtfsrt.api.translink.com.au/api/realtime/SEQ/TripUpdates
GTFS_RT_VEHICLE_POSITIONS_URL=https://gtfsrt.api.translink.com.au/api/realtime/SEQ/VehiclePositions
GTFS_RT_TIMEOUT_MS=4000

# Redis (external — set to your Proxmox LXC IP)
REDIS_URL=redis://192.168.1.x:6379

# Server
PORT=3000
